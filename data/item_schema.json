{
  "object_name": "Item__c",
  "description": "Represents an individual asbestos-containing item found during a building survey. Each Item__c has a required master-detail relationship to Building__c via Building_Code__c.",
  "fields": [

    {
      "api_name": "Item_ID__c",
      "label": "Item No",
      "type": "Number",
      "required": true,
      "max_length": 3,
      "description": "Sequential item number in ascending order (1,2,3...)"
    },
    {
      "api_name": "Building_Code__c",
      "label": "Building Name",
      "type": "Lookup",
      "required": true,
      "max_length": 18,
      "references": [
        "Building__c"
      ],
      "relationship_name": "Building_Code__r",
      "cascade_delete": true,
      "description": "Name of the building (e.g Myrtle Street Clinic, Mortuart Building, Pathology Department, VMO Accommodations, Main Hospital Building, Nurses Accommadation)"
    },
